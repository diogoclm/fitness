# Todas as variáveis abaixo ficam SÓ no servidor (sem prefixo VITE_) —
# nunca vão para o navegador.

# Chave da API da Anthropic (Claude). https://console.anthropic.com (precisa saldo).
ANTHROPIC_API_KEY=

# Postgres (Vercel Postgres / Neon). Connection string completa.
DATABASE_URL=

# Segredo para assinar os tokens de sessão (JWT). Gere um valor aleatório forte:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
AUTH_SECRET=
